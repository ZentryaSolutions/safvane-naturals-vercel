# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: run `npm run db:reviews` to create review tables via CLI
# Get from Supabase → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...

# Email notifications (optional for dev)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@safvane.com

# Site URL (for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
