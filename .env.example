# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: run `npm run db:reviews` to create review tables via CLI
# Get from Supabase → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...

# Email (Resend) — order confirmations + admin notifications
# 1. Sign up at https://resend.com
# 2. Add domain safvane.com → add DNS records in Zoho/domain registrar
# 3. Create API key → paste below
# 4. Use orders@safvane.com (or noreply@safvane.com) as FROM after domain verified
# Note: Zoho hosts your inbox; Resend sends transactional emails from your domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@safvane.com

# Site URL — MUST be your live domain on Vercel (never localhost in production).
# Wrong value here makes sitemap.xml and SEO point at localhost.
NEXT_PUBLIC_SITE_URL=https://www.safvane.com

# Meta Pixel (Facebook Ads / Events Manager)
NEXT_PUBLIC_META_PIXEL_ID=1591811942338255

# Meta Conversions API (server-side) — NEVER commit the real token
# Generate in Events Manager → Dataset → Settings → Generate access token
META_CAPI_ACCESS_TOKEN=
# Temporary for Test events tab only (e.g. TEST53318). Remove after testing.
# META_CAPI_TEST_EVENT_CODE=
